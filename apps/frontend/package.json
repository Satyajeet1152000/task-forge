{
  "name": "@task-forge/frontend",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "dotenv -e .env.development -- next dev --port 3001",
    "build": "tsc -p ../../packages/shared/tsconfig.json && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "echo '========= 🔍 ESLint... =========' && next lint --fix",
    "format:prettier": "echo '========= ✨ Prettier... =========' && prettier --write \"src/**/*.{ts,tsx}\"",
    "format": "npm run lint:fix && npm run format:prettier && echo '========= ✅ All formatting and linting done! ========='"
  },
  "dependencies": {
    "@task-forge/shared": "workspace:*",
    "next": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
