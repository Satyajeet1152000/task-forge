{
  "name": "@task-forge/frontend",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "env:setup": "node -e \"const fs=require('fs');const target='.env.development';if(!fs.existsSync(target)){fs.copyFileSync('.env.example',target);console.log('Created .env.development from .env.example');}\"",
    "dev": "npm run env:setup && dotenv -e .env.development -- next dev --port 3001",
    "build": "tsc -p ../../packages/shared/tsconfig.json && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "echo '========= 🔍 ESLint... =========' && next lint --fix",
    "format:prettier": "echo '========= ✨ Prettier... =========' && prettier --write \"src/**/*.{ts,tsx}\"",
    "format": "npm run lint:fix && npm run format:prettier && echo '========= ✅ All formatting and linting done! ========='"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.100.11",
    "@task-forge/shared": "workspace:*",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "lucide-react": "^1.16.0",
    "next": "^15.0.3",
    "next-auth": "5.0.0-beta.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.76.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
