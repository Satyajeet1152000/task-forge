{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "paths": {
      "@task-forge/shared/env": ["../../packages/shared/src/env.schema.ts"],
      "@task-forge/shared/schemas": ["../../packages/shared/src/schemas/index.ts"],
      "@task-forge/shared/types": ["../../packages/shared/src/types/index.ts"],
      "@task-forge/shared/constant": ["../../packages/shared/src/constant/index.ts"],
      "@lib/*": ["src/lib/*"],
      "@modules/*": ["src/modules/*"],
      "@plugins": ["src/plugins"],
      "@middleware/*": ["src/middleware/*"],
      "@utils/*": ["src/utils/*"],
      "@database/*": ["src/database/*"]
    }
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../../packages/shared" }],
  "exclude": ["node_modules", "dist"]
}
